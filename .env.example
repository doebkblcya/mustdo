DATABASE_URL=sqlite:///./todo_analyzer.db

# Use "mock" for local development without spending API tokens.
# Use "openai_compatible" for OpenAI or OpenAI-compatible providers.
AI_PROVIDER=mock
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=

# Configure at least AI_MODEL_BALANCED before using AI_PROVIDER=openai_compatible.
AI_MODEL_CHEAP=
AI_MODEL_BALANCED=
AI_MODEL_STRONG=

AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_OUTPUT_TOKENS=1200
AI_TEMPERATURE=0.1

# json_schema is most strict when the provider supports it.
# json_object is a compatibility fallback.
# none sends no response_format.
AI_RESPONSE_FORMAT=json_schema

# Optional. Some third-party gateways may reject this OpenAI-specific parameter.
AI_PROMPT_CACHE_KEY=

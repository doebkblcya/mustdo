# Browser runtime API origin. Leave empty to call same-origin /api.
# Example: VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# Vite dev-server proxy target. Used only when running `npm run dev`.
# Keep VITE_API_BASE_URL empty if you want the browser to call localhost:5173/api
# and let Vite proxy requests to the backend.
API_PROXY_TARGET=http://127.0.0.1:8000

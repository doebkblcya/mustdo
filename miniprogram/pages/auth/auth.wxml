<view class="auth-page page">
  <view class="auth-header">
    <text class="title">mustdo</text>
    <text class="headline">{{mode === 'register' ? '创建账号' : '欢迎回来'}}</text>
  </view>

  <view class="auth-panel">
    <view class="tabs">
      <button class="tab {{mode === 'login' ? 'active' : ''}}" bindtap="switchToLogin">登录</button>
      <button class="tab {{mode === 'register' ? 'active' : ''}}" bindtap="switchToRegister">注册</button>
    </view>

    <form bindsubmit="submit">
      <input class="field" name="username" value="{{username}}" placeholder="用户名" bindinput="onUsernameInput" />
      <view class="field password-field">
        <input class="password-input" name="password" value="{{password}}" password="{{!passwordVisible}}" placeholder="{{mode === 'register' ? '密码，至少 8 位' : '密码'}}" bindinput="onPasswordInput" />
        <button class="password-toggle" bindtap="togglePasswordVisible">{{passwordVisible ? '🙈' : '👁'}}</button>
      </view>
      <input wx:if="{{mode === 'register'}}" class="field" name="invite_code" value="{{inviteCode}}" placeholder="邀请码" bindinput="onInviteInput" />

      <text wx:if="{{error}}" class="error-text">{{error}}</text>

      <button class="primary-button" form-type="submit" loading="{{submitting}}">
        {{mode === 'register' ? '注册' : '登录'}}
      </button>
    </form>
  </view>
</view>

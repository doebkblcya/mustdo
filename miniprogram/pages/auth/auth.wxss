.auth-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.auth-header {
  margin-bottom: 44rpx;
}

.title {
  display: block;
  color: #14201a;
  font-size: 58rpx;
  font-weight: 800;
  line-height: 1.05;
}

.headline {
  display: block;
  margin-top: 16rpx;
  color: #66716a;
  font-size: 28rpx;
}

.auth-panel {
  padding: 28rpx;
  border: 1rpx solid #e4e9e3;
  border-radius: 34rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 46rpx rgba(24, 40, 32, 0.08);
}

.tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 8rpx;
  border-radius: 28rpx;
  background: #f1f5f1;
}

.tab {
  height: 66rpx;
  border-radius: 22rpx;
  color: #717b74;
  font-size: 28rpx;
}

.tab.active {
  background: #ffffff;
  color: #17664a;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(24, 40, 32, 0.06);
}

.field {
  margin-bottom: 18rpx;
}

.error-text {
  display: block;
  min-height: 42rpx;
  margin-bottom: 8rpx;
}

.auth-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-panel {
  width: 100%;
  max-width: 640rpx;
  padding: 44rpx;
  box-sizing: border-box;
}

.title {
  display: block;
  margin-bottom: 34rpx;
  color: rgba(13, 18, 24, 0.92);
  font-size: 42rpx;
  font-weight: 800;
}

.tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 6rpx;
  border: 1rpx solid rgba(118, 128, 140, 0.3);
  border-radius: 30rpx;
}

.tab {
  min-height: 64rpx;
  border-radius: 24rpx;
  color: rgba(35, 45, 55, 0.62);
  font-size: 28rpx;
}

.tab.active {
  background: rgba(255, 255, 255, 0.58);
  color: rgba(13, 18, 24, 0.92);
  box-shadow: 0 10rpx 24rpx rgba(30, 38, 46, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.field {
  margin-bottom: 20rpx;
}

.error-text {
  display: block;
  min-height: 44rpx;
  margin-bottom: 10rpx;
}

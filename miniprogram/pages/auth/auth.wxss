/*
 * Auth — Sign In / Sign Up
 * Apple Design · Refined typography, icons, depth · Balanced proportions
 */

/* ================================================================
   Page
   ================================================================ */

.auth-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 140rpx 40rpx 0;
  box-sizing: border-box;
  font-family: "SF Pro Display", "Inter", -apple-system, "Helvetica Neue", "PingFang SC", sans-serif;
}

/* ================================================================
   Hero
   ================================================================ */

.auth-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
  width: 100%;
}

.auth-wordmark {
  display: block;
  max-width: 100%;
  color: #1d1d1f;
  font-size: 60rpx;
  font-weight: 800;
  line-height: 1.08;
  letter-spacing: 3rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.auth-subtitle {
  display: block;
  margin-top: 14rpx;
  max-width: 100%;
  color: #6e6e73;
  font-size: 28rpx;
  font-weight: 300;
  line-height: 1.4;
  letter-spacing: 0.03em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ================================================================
   Segmented control — 78rpx total (5 + 68 + 5)
   ================================================================ */

.auth-tabs {
  position: relative;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 4rpx;
  width: 100%;
  margin-bottom: 28rpx;
  padding: 5rpx;
  border: 1rpx solid #d1d1d6;
  border-radius: 24rpx;
  background: #e5e5ea;
  box-sizing: border-box;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.auth-tab-pill {
  position: absolute;
  top: 5rpx;
  height: 68rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow:
    0 1rpx 3rpx rgba(0, 0, 0, 0.08),
    0 3rpx 10rpx rgba(0, 0, 0, 0.10);
  z-index: 0;
  pointer-events: none;
  will-change: transform;
}

.auth-tab {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68rpx;
  border-radius: 20rpx;
  background: transparent;
  overflow: hidden;
}

.auth-tab:active {
  transform: scale(0.97);
  transition: transform 80ms ease-out;
}

.auth-tab-label {
  display: block;
  max-width: 100%;
  color: #888888;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 8rpx;
  transition: color 0.2s ease;
}

.auth-tab.is-active .auth-tab-label {
  color: #1d1d1f;
  font-weight: 600;
}

/* ================================================================
   Form
   ================================================================ */

form {
  width: 100%;
  margin: 0;
  padding: 0;
}

.auth-form {
  width: 100%;
}

/* ================================================================
   Input field — 100rpx, unified radius 24rpx
   ================================================================ */

.auth-field {
  position: relative;
  display: flex;
  align-items: center;
  width: 100%;
  height: 100rpx;
  margin-bottom: 14rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d1d1d6;
  border-radius: 24rpx;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.auth-field:focus-within {
  border-color: #000000;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.auth-input {
  flex: 1;
  height: 100rpx;
  color: #1d1d1f;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 100rpx;
}

.auth-placeholder {
  color: #888888;
  font-size: 28rpx;
  font-weight: 400;
}

/* ---- Input icons ---- */

.auth-field-icon {
  flex-shrink: 0;
  margin-right: 16rpx;
}

.auth-field-icon--user {
  width: 22rpx;
  height: 22rpx;
  border: 1.5rpx solid #888888;
  border-radius: 50%;
  position: relative;
}
.auth-field-icon--user::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 30rpx;
  height: 14rpx;
  border: 1.5rpx solid #888888;
  border-radius: 15rpx 15rpx 0 0;
  border-bottom: none;
}

.auth-field-icon--lock {
  width: 18rpx;
  height: 16rpx;
  border: 1.5rpx solid #888888;
  border-radius: 3rpx;
  position: relative;
  margin-top: 4rpx;
}
.auth-field-icon--lock::after {
  content: '';
  position: absolute;
  top: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 14rpx;
  height: 12rpx;
  border: 1.5rpx solid #888888;
  border-radius: 7rpx 7rpx 0 0;
  border-bottom: none;
}

.auth-field-icon--invite {
  width: 22rpx;
  height: 16rpx;
  border: 1.5rpx solid #888888;
  border-radius: 3rpx;
  position: relative;
}
.auth-field-icon--invite::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 3rpx;
  right: 3rpx;
  height: 1.5rpx;
  background: #888888;
  transform: translateY(-50%);
}

/* ---- Password toggle — eye icon ---- */

.auth-field--password .auth-field-action {
  flex-shrink: 0;
  margin-left: 8rpx;
}

.auth-field-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
}

.auth-field-action:active {
  background: #f5f5f7;
  transform: scale(0.92);
  transition: transform 80ms ease-out;
}

.eye-icon {
  position: relative;
  width: 32rpx;
  height: 22rpx;
  border: 1.8rpx solid #888888;
  border-radius: 50%;
}
.eye-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8rpx;
  height: 8rpx;
  background: #888888;
  border-radius: 50%;
}

.eye-icon--off::before {
  content: '';
  position: absolute;
  top: 50%;
  left: -4rpx;
  right: -4rpx;
  height: 1.8rpx;
  background: #888888;
  transform: translateY(-50%) rotate(-30deg);
  z-index: 1;
}

/* ---- Error ---- */

.auth-error {
  display: block;
  min-height: 36rpx;
  padding: 10rpx 8rpx 4rpx;
  color: #ff3b30;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ---- Submit — 100rpx, gradient black ---- */

.auth-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100rpx;
  margin-top: 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #1c1c1c 0%, #000000 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.05em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.06),
    0 4rpx 20rpx rgba(0, 0, 0, 0.14);
  transition: transform 80ms ease-out, box-shadow 80ms ease-out;
}

.auth-submit:active {
  transform: scale(0.97);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04),
    0 2rpx 10rpx rgba(0, 0, 0, 0.10);
}

.auth-submit[disabled] {
  opacity: 0.45;
}

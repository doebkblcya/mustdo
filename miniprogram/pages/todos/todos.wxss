/*
 * Todos — Main list & interactions
 * Apple Design · Balanced proportions · Consistent with auth
 */

/* ================================================================
   Page
   ================================================================ */

.todos-page {
  padding-top: 24rpx;
  padding-bottom: calc(200rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* ================================================================
   Header bar
   ================================================================ */

.app-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 4rpx 20rpx;
}

.app-header .wordmark {
  display: block;
  font-family: "SF Pro Display", "Inter", -apple-system, "Helvetica Neue", "PingFang SC", sans-serif;
  color: #1d1d1f;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: 2rpx;
}

.app-header .greeting {
  display: block;
  margin-top: 4rpx;
  color: #6e6e73;
  font-size: 24rpx;
  font-weight: 400;
}

.logout-button {
  min-width: 96rpx;
  height: 60rpx;
  padding: 0 20rpx;
  border-radius: 30rpx;
  background: #ffffff;
  color: #6e6e73;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow:
    0 1rpx 3rpx rgba(0, 0, 0, 0.04),
    0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 80ms ease-out;
}

.logout-button:active {
  transform: scale(0.95);
}

/* ================================================================
   Summary card — black surface, white text
   ================================================================ */

.summary {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  min-height: 170rpx;
  margin-bottom: 28rpx;
  padding: 32rpx 32rpx 28rpx;
  border-radius: 28rpx;
  background: #1d1d1f;
  color: #ffffff;
  box-shadow:
    0 4rpx 16rpx rgba(0, 0, 0, 0.1),
    0 12rpx 36rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.summary::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -30rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
  pointer-events: none;
}

.summary-title {
  position: relative;
  z-index: 1;
  font-family: "SF Pro Display", "Inter", -apple-system, "Helvetica Neue", "PingFang SC", sans-serif;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: 2rpx;
}

.summary-meta {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}

.summary-date {
  color: rgba(255, 255, 255, 0.55);
  font-size: 24rpx;
  font-weight: 500;
}

.summary-count {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.9);
  font-size: 23rpx;
  font-weight: 600;
}

/* ================================================================
   Segmented control — sync with auth: 68rpx + 5rpx padding + border
   ================================================================ */

.tabs {
  position: relative;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4rpx;
  margin-bottom: 28rpx;
  padding: 5rpx;
  border: 1rpx solid #d1d1d6;
  border-radius: 24rpx;
  background: #e5e5ea;
  box-sizing: border-box;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.tab-pill {
  position: absolute;
  top: 5rpx;
  height: 68rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow:
    0 1rpx 3rpx rgba(0, 0, 0, 0.08),
    0 3rpx 10rpx rgba(0, 0, 0, 0.10);
  z-index: 0;
  pointer-events: none;
  will-change: transform;
}

.tab {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68rpx;
  border-radius: 20rpx;
  background: transparent;
  overflow: hidden;
}

.tab-label {
  display: block;
  max-width: 100%;
  color: #888888;
  font-size: 27rpx;
  font-weight: 500;
  line-height: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 6rpx;
  transition: color 0.2s ease;
}

.tab.active .tab-label {
  color: #1d1d1f;
  font-weight: 600;
}

.tab:active {
  transform: scale(0.97);
  transition: transform 80ms ease-out;
}

/* ================================================================
   Todo list
   ================================================================ */

.todo-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.todo-item {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 112rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #d1d1d6;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
  transition: box-shadow 0.2s ease, border-color 0.2s ease;
}

.todo-item:active {
  border-color: #000000;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.todo-item.done {
  opacity: 0.4;
}

.todo-item.deleting {
  opacity: 0;
  transition: opacity 0.22s ease;
}

/* ---- Check circle ---- */

.check-button {
  position: relative;
  z-index: 1;
  flex: 0 0 52rpx;
  width: 52rpx;
  height: 52rpx;
  border: 2.5rpx solid #d1d1d6;
  border-radius: 50%;
  background: transparent;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 52rpx;
  text-align: center;
  transition: border-color 0.15s ease, background 0.15s ease;
}

.todo-item.done .check-button {
  border-color: #1d1d1f;
  background: #1d1d1f;
}

/* ---- Content ---- */

.todo-content {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.todo-title {
  display: block;
  color: #1d1d1f;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.42;
  word-break: break-word;
}

.todo-item.done .todo-title {
  text-decoration: line-through;
  color: #888888;
}

.todo-meta {
  display: block;
  margin-top: 6rpx;
  color: #888888;
  font-size: 23rpx;
  font-weight: 500;
}

/* ---- Action buttons ---- */

.todo-actions {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 10rpx;
  flex: 0 0 auto;
}

.action-button {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #f5f5f7;
  color: #6e6e73;
  font-size: 24rpx;
  font-weight: 600;
}

.action-button:active {
  transform: scale(0.92);
  transition: transform 80ms ease-out;
  background: #e5e5ea;
}

.action-button.danger {
  background: rgba(255, 59, 48, 0.08);
  color: #ff3b30;
}

.action-button.danger:active {
  background: rgba(255, 59, 48, 0.16);
}

/* ---- Swipe delete ---- */

.delete-action {
  position: absolute;
  right: 22rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: #ff3b30;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 600;
  z-index: 0;
  pointer-events: none;
}

/* ================================================================
   Empty & error states
   ================================================================ */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 120rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 28rpx;
  line-height: 1;
  opacity: 0.4;
}

.empty-title {
  color: #1d1d1f;
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.empty-desc {
  color: #6e6e73;
  font-size: 27rpx;
  line-height: 1.5;
  max-width: 440rpx;
}

.retry-button {
  margin-top: 36rpx;
  max-width: 320rpx;
}

/* ================================================================
   Voice panel
   ================================================================ */

.voice-panel {
  position: fixed;
  right: 28rpx;
  bottom: calc(180rpx + constant(safe-area-inset-bottom));
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  left: 28rpx;
  z-index: 5;
  padding: 28rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(28px) saturate(180%);
  -webkit-backdrop-filter: blur(28px) saturate(180%);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow:
    0 4rpx 16rpx rgba(0, 0, 0, 0.08),
    0 16rpx 44rpx rgba(0, 0, 0, 0.12);
}

.voice-title {
  display: block;
  color: #1d1d1f;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.4;
}

.transcript {
  display: block;
  margin-top: 10rpx;
  color: #6e6e73;
  font-size: 27rpx;
  font-weight: 400;
  line-height: 1.45;
}

/* ================================================================
   Voice button
   ================================================================ */

.voice-button {
  position: fixed;
  right: 40rpx;
  bottom: calc(52rpx + constant(safe-area-inset-bottom));
  bottom: calc(52rpx + env(safe-area-inset-bottom));
  left: 40rpx;
  z-index: 6;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #1c1c1c 0%, #000000 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.05em;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.06),
    0 4rpx 20rpx rgba(0, 0, 0, 0.14);
}

.voice-button.recording {
  background: #ff3b30;
  color: #ffffff;
  box-shadow:
    0 4rpx 16rpx rgba(255, 59, 48, 0.25),
    0 12rpx 36rpx rgba(255, 59, 48, 0.18);
}

.voice-button.recording::after {
  content: '';
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  bottom: -6rpx;
  left: -6rpx;
  border-radius: 34rpx;
  border: 3rpx solid rgba(255, 59, 48, 0.3);
  animation: voicePulse 1.4s ease-out infinite;
  pointer-events: none;
}

@keyframes voicePulse {
  0%   { transform: scale(1); opacity: 0.7; }
  100% { transform: scale(1.06); opacity: 0; }
}

/* ================================================================
   Edit bottom sheet
   ================================================================ */

.sheet-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.edit-sheet {
  width: 100%;
  padding: 0 32rpx 48rpx;
  padding-bottom: calc(48rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow:
    0 -6rpx 24rpx rgba(0, 0, 0, 0.08),
    0 -24rpx 56rpx rgba(0, 0, 0, 0.14);
}

/* ---- Drag handle ---- */

.sheet-handle-area {
  display: flex;
  justify-content: center;
  padding: 16rpx 0 12rpx;
}

.sheet-handle {
  width: 64rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #d1d1d6;
}

/* ---- Sheet header ---- */

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.sheet-title {
  font-family: "SF Pro Display", "Inter", -apple-system, "Helvetica Neue", "PingFang SC", sans-serif;
  color: #1d1d1f;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.sheet-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f7;
  color: #6e6e73;
  font-size: 32rpx;
  font-weight: 400;
  line-height: 1;
}

.sheet-close:active {
  background: #e5e5ea;
  transform: scale(0.9);
  transition: transform 80ms ease-out;
}

/* ---- Edit form ---- */

.edit-field {
  margin-bottom: 14rpx;
}

.edit-placeholder {
  color: #888888;
  font-size: 28rpx;
  font-weight: 400;
}

.edit-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  margin-top: 14rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d1d1d6;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.edit-label {
  color: #6e6e73;
  font-size: 28rpx;
  font-weight: 500;
}

.picker-value,
.time-picker {
  color: #1d1d1f;
  font-size: 28rpx;
  font-weight: 500;
}

.time-picker {
  margin-top: 14rpx;
  padding: 24rpx 24rpx;
  border: 1rpx solid #d1d1d6;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  text-align: right;
}

.save-button {
  margin-top: 28rpx;
}

/* ================================================================
   Reduced motion
   ================================================================ */

page.reduced-motion .edit-sheet,
page.reduced-motion .voice-panel {
  transition: opacity 200ms ease;
}

page.reduced-motion .voice-button.recording::after {
  animation: none;
  opacity: 0;
}

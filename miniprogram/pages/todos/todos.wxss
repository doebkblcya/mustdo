.todos-page {
  padding-bottom: 180rpx;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  padding: 24rpx 28rpx;
}

.brand {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
}

.user {
  display: block;
  margin-top: 6rpx;
  color: rgba(35, 45, 55, 0.62);
  font-size: 24rpx;
}

.logout,
.delete {
  min-width: 72rpx;
  min-height: 56rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.45);
  color: rgba(35, 45, 55, 0.72);
  font-size: 24rpx;
}

.tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-bottom: 22rpx;
  padding: 8rpx;
}

.tab {
  min-height: 72rpx;
  border-radius: 26rpx;
  color: rgba(35, 45, 55, 0.62);
  font-size: 28rpx;
}

.tab.active {
  background: rgba(255, 255, 255, 0.58);
  color: rgba(13, 18, 24, 0.92);
  box-shadow: 0 12rpx 30rpx rgba(30, 38, 46, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.todo-panel {
  min-height: 640rpx;
  overflow: hidden;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border-bottom: 1rpx solid rgba(118, 128, 140, 0.24);
}

.panel-title {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
}

.panel-date,
.count {
  color: rgba(35, 45, 55, 0.62);
  font-size: 24rpx;
}

.todo-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(118, 128, 140, 0.18);
}

.todo-row.done {
  opacity: 0.45;
}

.check {
  width: 46rpx;
  height: 46rpx;
  border: 2rpx solid rgba(13, 18, 24, 0.72);
  border-radius: 50%;
  color: rgba(13, 18, 24, 0.92);
  font-size: 28rpx;
  line-height: 46rpx;
}

.todo-main {
  flex: 1;
  min-width: 0;
}

.todo-title {
  display: block;
  color: rgba(13, 18, 24, 0.92);
  font-size: 30rpx;
  line-height: 1.45;
}

.todo-meta {
  display: block;
  margin-top: 8rpx;
  color: rgba(35, 45, 55, 0.58);
  font-size: 23rpx;
}

.empty {
  padding: 120rpx 0;
  text-align: center;
  color: rgba(35, 45, 55, 0.56);
  font-size: 28rpx;
}

.voice-panel {
  position: fixed;
  right: 28rpx;
  bottom: 170rpx;
  left: 28rpx;
  z-index: 5;
  padding: 26rpx;
}

.voice-title,
.transcript,
.voice-debug {
  display: block;
  font-size: 27rpx;
}

.transcript {
  margin-top: 14rpx;
  color: rgba(35, 45, 55, 0.78);
}

.voice-debug {
  margin-top: 12rpx;
  color: rgba(35, 45, 55, 0.52);
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-all;
}

.voice-button {
  position: fixed;
  right: 50rpx;
  bottom: 54rpx;
  left: 50rpx;
  z-index: 6;
  min-height: 92rpx;
  border-radius: 34rpx;
  background: rgba(13, 18, 24, 0.9);
  color: #ffffff;
  font-size: 32rpx;
  box-shadow: 0 22rpx 50rpx rgba(30, 38, 46, 0.26);
}

.voice-button.recording {
  background: #ba1f2f;
}

.todos-page {
  padding-bottom: calc(184rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(184rpx + env(safe-area-inset-bottom));
}

.app-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 4rpx 28rpx;
}

.brand {
  display: block;
  color: #14201a;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.1;
}

.user {
  display: block;
  margin-top: 8rpx;
  color: #778179;
  font-size: 24rpx;
}

.logout-button {
  min-width: 92rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: #ffffff;
  color: #5f6962;
  font-size: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 40, 32, 0.06);
}

.summary {
  display: grid;
  grid-template-columns: 1fr auto;
  row-gap: 8rpx;
  align-items: end;
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #183d31, #17664a);
  color: #ffffff;
  box-shadow: 0 22rpx 48rpx rgba(23, 102, 74, 0.22);
}

.summary-title {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
}

.summary-date {
  grid-column: 1;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
}

.summary-count {
  grid-column: 2;
  grid-row: 1 / span 2;
  padding: 12rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
}

.tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 8rpx;
  border: 1rpx solid #e3e7e1;
  border-radius: 28rpx;
  background: #ffffff;
}

.tab {
  height: 68rpx;
  border-radius: 22rpx;
  color: #717b74;
  font-size: 28rpx;
  transition: background 0.2s ease, color 0.2s ease;
}

.tab.active {
  background: #e8f3ec;
  color: #17664a;
  font-weight: 700;
}

.todo-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.todo-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 116rpx;
  padding: 22rpx 20rpx;
  border: 1rpx solid #e5e9e4;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(24, 40, 32, 0.05);
  transition: opacity 0.25s ease, transform 0.2s ease;
}

.todo-item:active {
  transform: scale(0.985);
}

.todo-item.done {
  opacity: 0.5;
}

.check-button {
  flex: 0 0 48rpx;
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #17664a;
  border-radius: 50%;
  color: #17664a;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 48rpx;
  transition: background 0.15s ease;
}

.todo-item.done .check-button {
  background: #17664a;
  color: #ffffff;
}

.todo-content {
  flex: 1;
  min-width: 0;
}

.todo-title {
  display: block;
  color: #182820;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.45;
  word-break: break-word;
}

.todo-meta {
  display: block;
  margin-top: 8rpx;
  color: #7d877f;
  font-size: 23rpx;
}

.todo-actions {
  display: flex;
  gap: 10rpx;
  flex: 0 0 auto;
}

.action-button {
  width: 58rpx;
  height: 58rpx;
  border-radius: 20rpx;
  background: #eef3ef;
  color: #44514a;
  font-size: 24rpx;
  line-height: 58rpx;
}

.action-button.danger {
  background: #fff0f1;
  color: #ba1f2f;
}

/* Empty & error states */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx 120rpx;
  text-align: center;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
  line-height: 1;
}

.empty-title {
  color: #182820;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.empty-desc {
  color: #8b948d;
  font-size: 26rpx;
  line-height: 1.55;
  max-width: 420rpx;
}

.retry-button {
  margin-top: 32rpx;
  max-width: 320rpx;
}

/* Voice panel with safe area */
.voice-panel {
  position: fixed;
  right: 28rpx;
  bottom: calc(166rpx + constant(safe-area-inset-bottom));
  bottom: calc(166rpx + env(safe-area-inset-bottom));
  left: 28rpx;
  z-index: 5;
  padding: 24rpx 28rpx;
  border: 1rpx solid #dde4de;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 44rpx rgba(24, 40, 32, 0.12);
  backdrop-filter: blur(20rpx);
}

.voice-title,
.transcript {
  display: block;
  font-size: 27rpx;
  line-height: 1.45;
}

.voice-title {
  color: #17664a;
  font-weight: 700;
}

.transcript {
  margin-top: 12rpx;
  color: #44514a;
}

/* Voice button with safe area */
.voice-button {
  position: fixed;
  right: 42rpx;
  bottom: calc(48rpx + constant(safe-area-inset-bottom));
  bottom: calc(48rpx + env(safe-area-inset-bottom));
  left: 42rpx;
  z-index: 6;
  height: 94rpx;
  border-radius: 47rpx;
  background: #14201a;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 22rpx 48rpx rgba(20, 32, 26, 0.22);
  transition: background 0.2s ease, transform 0.15s ease;
}

.voice-button:active {
  transform: scale(0.97);
}

.voice-button.recording {
  background: #ba1f2f;
}

/* Edit bottom sheet */
.sheet-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  display: flex;
  align-items: flex-end;
  background: rgba(20, 32, 26, 0.32);
  animation: maskFadeIn 0.25s ease both;
}

.sheet-mask.sheet-closing {
  animation: maskFadeOut 0.25s ease both;
}

.edit-sheet {
  width: 100%;
  padding: 30rpx 28rpx 44rpx;
  padding-bottom: calc(44rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(44rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 -18rpx 48rpx rgba(20, 32, 26, 0.14);
  animation: sheetSlideUp 0.3s cubic-bezier(0.32, 0.72, 0, 1) both;
}

.edit-sheet.sheet-closing {
  animation: sheetSlideDown 0.3s cubic-bezier(0.32, 0.72, 0, 1) both;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26rpx;
}

.sheet-title {
  color: #14201a;
  font-size: 34rpx;
  font-weight: 800;
}

.sheet-close {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #f1f4f1;
  color: #68736b;
  font-size: 38rpx;
  line-height: 52rpx;
}

.edit-field {
  margin-bottom: 18rpx;
}

.edit-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 84rpx;
  margin-top: 14rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e1e6e0;
  border-radius: 24rpx;
  background: #f8faf8;
}

.edit-label {
  color: #68736b;
  font-size: 27rpx;
}

.picker-value,
.time-picker {
  color: #182820;
  font-size: 29rpx;
  font-weight: 600;
}

.time-picker {
  margin-top: 14rpx;
  padding: 24rpx;
  border: 1rpx solid #e1e6e0;
  border-radius: 24rpx;
  background: #f8faf8;
  text-align: right;
}

.save-button {
  margin-top: 24rpx;
}

<view class="todos-page page">
  <view class="app-header">
    <view>
      <text class="wordmark">mustdo</text>
      <text class="greeting">{{user ? user.username : ''}}</text>
    </view>
    <button class="logout-button" bindtap="logout">退出</button>
  </view>

  <view class="summary">
    <text class="summary-title">{{viewTitle}}</text>
    <view class="summary-meta">
      <text class="summary-date">{{viewDate}}</text>
      <text class="summary-count">{{items.length}} 项</text>
    </view>
  </view>

  <view class="tabs">
    <view class="tab-pill" style="width: {{pillWidth}}px; transform: translateX({{pillX}}px);"></view>
    <button class="tab {{activeView === 'today' ? 'active' : ''}}" data-view="today" bindtap="switchView">
      <text class="tab-label">今天</text>
    </button>
    <button class="tab {{activeView === 'tomorrow' ? 'active' : ''}}" data-view="tomorrow" bindtap="switchView">
      <text class="tab-label">明天</text>
    </button>
    <button class="tab {{activeView === 'upcoming' ? 'active' : ''}}" data-view="upcoming" bindtap="switchView">
      <text class="tab-label">后续</text>
    </button>
  </view>

  <view class="todo-list">
    <!-- Skeleton loading -->
    <block wx:if="{{loading}}">
      <view wx:for="{{[1,2,3,4]}}" wx:key="*this" class="skeleton-card">
        <view class="skeleton-line" style="width:52rpx;height:52rpx;border-radius:50%;flex:0 0 52rpx;"></view>
        <view style="flex:1;display:flex;flex-direction:column;gap:14rpx;">
          <view class="skeleton-line" style="width:70%;"></view>
          <view class="skeleton-line" style="width:44%;"></view>
        </view>
      </view>
    </block>

    <!-- Error state -->
    <view wx:elif="{{error}}" class="empty-state">
      <text class="empty-icon">⚠️</text>
      <text class="empty-title">加载失败</text>
      <text class="empty-desc">{{error}}</text>
      <button class="primary-button retry-button" bindtap="loadTodos">重试</button>
    </view>

    <!-- Empty state -->
    <view wx:elif="{{items.length === 0}}" class="empty-state">
      <text class="empty-icon">{{activeView === 'today' ? '☀️' : activeView === 'tomorrow' ? '📅' : '📋'}}</text>
      <text class="empty-title">暂无待办</text>
      <text class="empty-desc">{{activeView === 'today' ? '今天还没有待办事项，放松一下' : activeView === 'tomorrow' ? '明天还没有计划，提前安排？' : '后续没有待办，一切尽在掌握'}}</text>
    </view>

    <!-- Todo items -->
    <block wx:else>
      <view
        wx:for="{{items}}"
        wx:key="id"
        class="todo-item {{item.status === 'done' ? 'done' : ''}} {{item.deleting ? 'deleting' : ''}}"
        style="transform: translateX({{item.swipeX || 0}}rpx);"
        bindtouchstart="onItemTouchStart"
        bindtouchmove="onItemTouchMove"
        bindtouchend="onItemTouchEnd"
        data-index="{{index}}"
        data-id="{{item.id}}"
      >
        <view class="delete-action" style="opacity: {{item.swipeX ? (-item.swipeX / 120) : 0}};">
          <text>删除</text>
        </view>
        <button
          class="check-button"
          style="transform: scale({{item.checkScale || 1}});"
          data-id="{{item.id}}"
          data-status="{{item.status}}"
          data-index="{{index}}"
          bindtap="toggleTodo"
        >
          {{item.status === 'done' ? '✓' : ''}}
        </button>
        <view class="todo-content">
          <text class="todo-title">{{item.content}}</text>
          <text class="todo-meta">{{item.meta}}</text>
        </view>
        <view class="todo-actions">
          <button class="action-button" data-id="{{item.id}}" bindtap="editTodo">改</button>
          <button class="action-button danger" data-id="{{item.id}}" bindtap="deleteTodo">删</button>
        </view>
      </view>
    </block>
  </view>

  <!-- Voice status panel -->
  <view wx:if="{{voiceMessage || transcript}}" class="voice-panel" style="transform: translateY({{voicePanelY || 16}}rpx); opacity: {{voicePanelOpacity || 0}};">
    <text class="voice-title">{{voiceMessage}}</text>
    <text wx:if="{{transcript}}" class="transcript">{{transcript}}</text>
  </view>

  <!-- Hold-to-talk button -->
  <button
    class="voice-button {{recording ? 'recording' : ''}}"
    style="transform: scale({{voiceButtonScale || 1}});"
    catchtouchstart="startVoice"
    catchtouchend="stopVoice"
    catchtouchcancel="stopVoice"
  >
    {{recording ? '松开完成' : '按住说话'}}
  </button>

  <!-- Edit bottom sheet -->
  <view
    wx:if="{{editVisible}}"
    class="sheet-mask"
    style="opacity: {{maskOpacity}};"
    catchtap="cancelEdit"
    catchtouchmove="noop"
  >
    <view
      class="edit-sheet"
      style="transform: translateY({{sheetTranslateY}}px);"
    >
      <!-- Drag handle -->
      <view
        class="sheet-handle-area"
        catchtouchstart="onSheetTouchStart"
        catchtouchmove="onSheetTouchMove"
        catchtouchend="onSheetTouchEnd"
      >
        <view class="sheet-handle"></view>
      </view>

      <view class="sheet-head">
        <text class="sheet-title">修改待办</text>
        <button class="sheet-close" bindtap="cancelEdit">×</button>
      </view>

      <input
        class="field edit-field"
        value="{{editContent}}"
        placeholder="待办内容"
        placeholder-class="edit-placeholder"
        confirm-type="done"
        bindinput="onEditContentInput"
      />

      <view class="edit-row">
        <text class="edit-label">日期</text>
        <picker mode="date" value="{{editDate}}" start="{{todayDate}}" bindchange="onEditDateChange">
          <view class="picker-value">{{editDate}}</view>
        </picker>
      </view>

      <view class="edit-row">
        <text class="edit-label">时间</text>
        <switch checked="{{editUseTime}}" color="#1d1d1f" bindchange="onEditUseTimeChange" />
      </view>

      <picker wx:if="{{editUseTime}}" mode="time" value="{{editTime}}" bindchange="onEditTimeChange">
        <view class="time-picker">{{editTime}}</view>
      </picker>

      <button class="primary-button save-button" loading="{{editSubmitting}}" bindtap="submitEdit">保存</button>
    </view>
  </view>
</view>

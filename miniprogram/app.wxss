/*
 * mustdo — Apple Design System · Light Mode
 *
 * Depth hierarchy (light → dark):
 *   bg           #f2f2f7    page background (iOS system)
 *   surface      #ffffff    cards, panels — level 1
 *   surface-2    #f5f5f7    inset / grouped — level 0
 *   border       #e5e5ea    separators, hairline
 *   text         #1d1d1f    primary
 *   text-2       #6e6e73    secondary
 *   text-3       #888888    tertiary / placeholder (deepened for legibility)
 *   accent       #1d1d1f    dark button bg, active states
 *   destructive  #ff3b30    delete, error
 *
 * Typography scale (rpx):
 *   display    58    -0.02em   800   1.08
 *   title-1    48    -0.02em   800   1.12
 *   title-2    40    -0.015em  700   1.18
 *   headline   34    -0.01em   700   1.22
 *   body       30     0        500   1.50
 *   callout    27     0        500   1.45
 *   footnote   24     0        500   1.40
 *   caption    22     0.01em   500   1.35
 *
 * Spacing scale (rpx): 4 8 12 16 20 24 28 32 36 40 44 48 56 64 72
 * Radius scale (rpx):  8 12 16 20 24 28 32 36 40
 */

/* ================================================================
   Root — page base
   ================================================================ */

page {
  min-height: 100vh;
  background: #f2f2f7;
  color: #1d1d1f;
  font-family: "SF Pro Display", "Inter", -apple-system, "Helvetica Neue", "PingFang SC", sans-serif;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* ================================================================
   Reset
   ================================================================ */

button {
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  line-height: inherit;
  font-size: inherit;
  color: inherit;
  text-align: inherit;
}

button::after {
  display: none;
}

input {
  font-family: inherit;
  font-size: inherit;
  color: inherit;
}

/* ================================================================
   Page shell
   ================================================================ */

.page {
  min-height: 100vh;
  padding: 0 32rpx;
  padding-top: 0;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

/* ================================================================
   Typography primitives
   ================================================================ */

.display {
  font-size: 58rpx;
  font-weight: 800;
  line-height: 1.08;
  letter-spacing: -0.02em;
}

.title-1 {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.12;
  letter-spacing: -0.02em;
}

.title-2 {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.18;
  letter-spacing: -0.015em;
}

.headline {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.22;
  letter-spacing: -0.01em;
}

.body-text {
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1.5;
}

.callout {
  font-size: 27rpx;
  font-weight: 500;
  line-height: 1.45;
}

.footnote {
  font-size: 24rpx;
  font-weight: 400;
  line-height: 1.4;
  color: #6e6e73;
}

.caption {
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.35;
  letter-spacing: 0.01em;
  color: #888888;
}

/* ================================================================
   Form fields — white surface, hairline border
   ================================================================ */

.field {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx;
  border: 1.5rpx solid #d1d1d6;
  border-radius: 24rpx;
  background: #ffffff;
  box-sizing: border-box;
  color: #1d1d1f;
  font-size: 30rpx;
  font-weight: 400;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.field:focus {
  border-color: #000000;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* ================================================================
   Primary button — dark, prominent
   ================================================================ */

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #1c1c1c 0%, #000000 100%);
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 600;
  letter-spacing: 0.04em;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.06),
    0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  transition: transform 80ms ease-out, box-shadow 80ms ease-out;
}

.primary-button:active {
  transform: scale(0.97);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04),
    0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* ================================================================
   Secondary button — outline style
   ================================================================ */

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  border-radius: 28rpx;
  border: 1.5rpx solid #d1d1d6;
  background: #ffffff;
  color: #1d1d1f;
  font-size: 31rpx;
  font-weight: 600;
  letter-spacing: -0.01em;
  transition: transform 80ms ease-out, background 80ms ease-out;
}

.secondary-button:active {
  transform: scale(0.97);
  background: #f5f5f7;
}

/* ================================================================
   Error text
   ================================================================ */

.error-text {
  display: block;
  color: #ff3b30;
  font-size: 25rpx;
  font-weight: 500;
  line-height: 1.4;
}

/* ================================================================
   Skeleton loading
   ================================================================ */

@keyframes shimmer {
  0%   { opacity: 0.3; }
  50%  { opacity: 0.6; }
  100% { opacity: 0.3; }
}

.skeleton-line {
  height: 26rpx;
  border-radius: 13rpx;
  background: #e5e5ea;
  animation: shimmer 1.6s ease-in-out infinite;
}

.skeleton-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 120rpx;
  padding: 24rpx 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
}

/* ================================================================
   Reduced motion fallbacks
   ================================================================ */

page.reduced-motion .skeleton-line {
  animation: none;
  opacity: 0.45;
}

page.reduced-motion .tab-pill {
  transition: transform 0.15s ease !important;
}

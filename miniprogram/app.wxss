page {
  min-height: 100vh;
  background: #f6f8f5;
  color: #182820;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1.4;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 42rpx 28rpx 136rpx;
  box-sizing: border-box;
}

.field {
  width: 100%;
  height: 84rpx;
  padding: 0 24rpx;
  border: 1rpx solid #dfe5de;
  border-radius: 24rpx;
  background: #ffffff;
  box-sizing: border-box;
  color: #182820;
  font-size: 30rpx;
}

.primary-button {
  width: 100%;
  height: 86rpx;
  border-radius: 28rpx;
  background: #17664a;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 34rpx rgba(23, 102, 74, 0.18);
}

.error-text {
  color: #ba1f2f;
  font-size: 26rpx;
  line-height: 1.45;
}

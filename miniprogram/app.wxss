page {
  min-height: 100vh;
  background: #ffffff;
  color: rgba(13, 18, 24, 0.92);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1.4;
}

.page {
  min-height: 100vh;
  padding: 40rpx 28rpx 136rpx;
  box-sizing: border-box;
}

.glass {
  border: 1rpx solid rgba(118, 128, 140, 0.28);
  border-radius: 36rpx;
  background: linear-gradient(145deg, rgba(232, 236, 240, 0.82), rgba(214, 220, 226, 0.58));
  box-shadow: 0 26rpx 74rpx rgba(30, 38, 46, 0.14), inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.field {
  width: 100%;
  min-height: 78rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(118, 128, 140, 0.36);
  border-radius: 28rpx;
  background: rgba(232, 236, 240, 0.72);
  box-sizing: border-box;
  color: rgba(13, 18, 24, 0.92);
  font-size: 30rpx;
}

.primary-button {
  width: 100%;
  min-height: 82rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.55);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8), 0 12rpx 30rpx rgba(30, 38, 46, 0.08);
  color: rgba(13, 18, 24, 0.92);
  font-size: 30rpx;
}

.error-text {
  color: #ba1f2f;
  font-size: 26rpx;
}
